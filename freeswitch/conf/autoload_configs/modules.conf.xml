<!--
  freeswitch/conf/autoload_configs/modules.conf.xml
  ==================================================
  Módulos essenciais + mod_audio_fork

  Se mod_audio_fork não estiver disponível no pacote SignalWire,
  compile manualmente — veja o Dockerfile do FreeSWITCH abaixo.
-->
<configuration name="modules.conf" description="Modules">
  <modules>

    <!-- Endpoints -->
    <load module="mod_sofia"/>

    <!-- Dialplan -->
    <load module="mod_dialplan_xml"/>

    <!-- Codecs de áudio -->
    <load module="mod_opus"/>
    <load module="mod_g723_1"/>
    <load module="mod_g729"/>
    <load module="mod_amr"/>
    <load module="mod_ilbc"/>
    <load module="mod_speex"/>
    <load module="mod_siren"/>
    <load module="mod_celt"/>
    <load module="mod_h26x"/>

    <!-- PCM / raw -->
    <load module="mod_sndfile"/>
    <load module="mod_native_file"/>

    <!-- ─── CRÍTICO: Fork de áudio para WebSocket ─────────────────── -->
    <!-- Requer compilação manual — veja Dockerfile do FreeSWITCH      -->
    <load module="mod_audio_fork"/>

    <!-- Aplicações de mídia -->
    <load module="mod_dptools"/>
    <load module="mod_playback"/>
    <load module="mod_record_session"/>
    <load module="mod_tone_detect"/>
    <load module="mod_silence_detect"/>
    <load module="mod_conference"/>

    <load module="mod_tone_stream"/>
    <load module="mod_loopback"/>

    <!-- ESL (Event Socket — usado pelo bridge.py) -->
    <load module="mod_event_socket"/>

    <!-- Logging -->
    <load module="mod_logfile"/>
    <load module="mod_console"/>

    <!-- Utilitários -->
    <load module="mod_commands"/>
    <load module="mod_say_en"/>

  </modules>
</configuration>
