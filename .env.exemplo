# =============================================================================
# freeswitch-midia-fullduplex - Environment Variables
# =============================================================================

# --- Infra / Build -----------------------------------------------------------
# Token do SignalWire para build do FreeSWITCH (mod_audio_fork).
SIGNALWIRE_TOKEN=meu_token_signalwire

# --- Rede (FreeSWITCH Host Mode) --------------------------------------------
EXTERNAL_IP=meu_ip_publico
INTERNAL_IP=meu_ip_privado
AF_SPEEX_DENOISE_ENABLE=1
AF_SPEEX_NOISE_SUPPRESS_DB=-25

# --- SpeexDSP Denoise (pré-resample, 8kHz) ----------------------------------
# Supressão de ruído leve antes do upsample 8k→16k. Opera em narrowband (8kHz),
# adequado para PSTN/celular.
# 1=habilitado, 0=desabilitado.
AF_SPEEX_DENOISE_ENABLE=1
# Supressão em dB (quanto mais negativo, mais agressivo).
# -22: leve, preserva ataque de consoantes | -25: padrão | -30: agressivo
AF_SPEEX_NOISE_SUPPRESS_DB=-22

# --- Bot (Runtime) -----------------------------------------------------------
BOT_WS_PORT=8000
LOG_LEVEL=INFO
SYSTEM_PROMPT=Você é a Astra, uma assistente de voz inteligente e prestativa. Responda de forma clara, concisa e natural para uma conversa por telefone. Limite suas respostas a 1-3 frases curtas. Não use emojis, markdown ou formatação especial.

# --- STT / LLM / TTS ---------------------------------------------------------
DEEPGRAM_API_KEY=minha_api_key
STT_MODEL=nova-3

OPENAI_API_KEY=minha_api_key
OPENAI_API_BASE=https://api.inceptionlabs.ai/v1
OPENAI_MODEL=mercury-2

CARTESIA_API_KEY=minha_api_key
TTS_MODEL=sonic-2
TTS_VOICE=0e1b0b5a-e1ba-46eb-b24d-51e4ad3679fd
TTS_LANGUAGE=pt

# API de pesquisa para consultas em tempo real
SERPAPI_API_KEY=minha_api_key_serpapi

